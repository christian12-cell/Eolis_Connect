# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://eolisconnect.online,https://www.eolisconnect.online

# ── Email (Zoho) ──────────────────────────────────────────────────────────────
MAIL_ENABLED=true
MAIL_SERVER=smtp.zoho.eu
MAIL_PORT=587
MAIL_NOREPLY_FROM=noreply@eolisconnect.online
MAIL_NOREPLY_PASSWORD=your-zoho-password
MAIL_SUPPORT_FROM=support@eolisconnect.online
ADMIN_EMAIL=admin@eolisconnect.online

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS S3 (fichiers uploadés) ────────────────────────────────────────────────
USE_S3=true
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=eolis-connect-uploads
